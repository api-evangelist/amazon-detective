{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-detective/refs/heads/main/json-schema/amazon-detective-batch-get-membership-datasources-request-schema.json",
  "title": "BatchGetMembershipDatasourcesRequest",
  "description": "Request to get datasource package history for accounts",
  "type": "object",
  "properties": {
    "GraphArns": {
      "type": "array",
      "description": "The ARN of the behavior graph.",
      "items": {
        "type": "string"
      },
      "example": [
        "arn:aws:detective:us-east-1:123456789012:graph:abc123def456"
      ]
    }
  },
  "required": [
    "GraphArns"
  ]
}